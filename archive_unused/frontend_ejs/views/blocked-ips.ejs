<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= title %></title>
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
      rel="stylesheet"
    />
    <link rel="stylesheet" href="/css/styles.css" />
  </head>
  <body class="bg-dark text-light">
    <nav class="navbar navbar-expand-lg navbar-dark bg-black border-bottom border-secondary">
      <div class="container-fluid">
        <a class="navbar-brand fw-bold" href="/">AI IDS Platform</a>
        <button
          class="navbar-toggler"
          type="button"
          data-bs-toggle="collapse"
          data-bs-target="#navbarNav"
        >
          <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse" id="navbarNav">
          <ul class="navbar-nav ms-auto">
            <li class="nav-item">
              <a class="nav-link" href="/">Dashboard</a>
            </li>
            <li class="nav-item">
              <a class="nav-link" href="/live-traffic">Live Traffic</a>
            </li>
            <li class="nav-item">
              <a class="nav-link" href="/attack-logs">Attack Logs</a>
            </li>
            <li class="nav-item">
              <a class="nav-link active" href="/blocked-ips">Blocked IPs</a>
            </li>
          </ul>
        </div>
      </div>
    </nav>

    <main class="container py-4">
      <h1 class="mb-4">Blocked IPs</h1>

      <div class="card bg-secondary text-light">
        <div class="card-body">
          <div class="d-flex justify-content-between align-items-center mb-3">
            <h5 class="card-title mb-0">Current Block List</h5>
            <span class="text-muted small">Total blocked IPs: <%= (blockedIps || []).length %></span>
          </div>
          <div class="table-responsive" style="max-height: 480px;">
            <table class="table table-sm table-dark table-striped align-middle">
              <thead>
                <tr>
                  <th>IP Address</th>
                  <th>Severity</th>
                  <th>First Blocked</th>
                  <th>Last Seen</th>
                  <th>Status</th>
                  <th>Reason</th>
                </tr>
              </thead>
              <tbody>
                <% if (blockedIps && blockedIps.length) { %>
                  <% blockedIps.forEach(function (ip) { %>
                    <tr>
                      <td><%= ip.ip_address %></td>
                      <td class="text-capitalize"><%= ip.severity %></td>
                      <td><%= ip.first_blocked_at && new Date(ip.first_blocked_at).toLocaleString() %></td>
                      <td><%= ip.last_seen_at && new Date(ip.last_seen_at).toLocaleString() %></td>
                      <td>
                        <% if (ip.is_blocked) { %>
                          <span class="badge bg-danger">Blocked</span>
                        <% } else { %>
                          <span class="badge bg-secondary">Unblocked</span>
                        <% } %>
                      </td>
                      <td><%= ip.reason || '-' %></td>
                    </tr>
                  <% }) %>
                <% } else { %>
                  <tr>
                    <td colspan="6" class="text-center text-muted">No blocked IPs yet.</td>
                  </tr>
                <% } %>
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </main>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  </body>
  </html>

