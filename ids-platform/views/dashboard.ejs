<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= title %></title>
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
      rel="stylesheet"
    />
    <link rel="stylesheet" href="/css/styles.css" />
  </head>
  <body class="bg-dark text-light">
    <nav class="navbar navbar-expand-lg navbar-dark bg-black border-bottom border-secondary">
      <div class="container-fluid">
        <a class="navbar-brand fw-bold" href="/">AI IDS Platform</a>
        <button
          class="navbar-toggler"
          type="button"
          data-bs-toggle="collapse"
          data-bs-target="#navbarNav"
        >
          <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse" id="navbarNav">
          <ul class="navbar-nav ms-auto">
            <li class="nav-item">
              <a class="nav-link active" href="/">Dashboard</a>
            </li>
            <li class="nav-item">
              <a class="nav-link" href="/live-traffic">Live Traffic</a>
            </li>
            <li class="nav-item">
              <a class="nav-link" href="/attack-logs">Attack Logs</a>
            </li>
            <li class="nav-item">
              <a class="nav-link" href="/blocked-ips">Blocked IPs</a>
            </li>
          </ul>
        </div>
      </div>
    </nav>

    <main class="container py-4">
      <h1 class="mb-4">Intrusion Detection &amp; Prevention Dashboard</h1>

      <div class="row g-3 mb-4">
        <div class="col-md-3">
          <div class="card bg-secondary text-light h-100">
            <div class="card-body">
              <h6 class="card-title text-uppercase small">Total Traffic Analyzed</h6>
              <p class="display-6 mb-0"><%= metrics.totalTraffic %></p>
            </div>
          </div>
        </div>
        <div class="col-md-3">
          <div class="card bg-danger text-light h-100">
            <div class="card-body">
              <h6 class="card-title text-uppercase small">Attacks Detected</h6>
              <p class="display-6 mb-0"><%= metrics.totalAttacks %></p>
            </div>
          </div>
        </div>
        <div class="col-md-3">
          <div class="card bg-info text-dark h-100">
            <div class="card-body">
              <h6 class="card-title text-uppercase small">Detection Rate</h6>
              <p class="display-6 mb-0"><%= metrics.detectionRate %> %</p>
            </div>
          </div>
        </div>
        <div class="col-md-3">
          <div class="card bg-warning text-dark h-100">
            <div class="card-body">
              <h6 class="card-title text-uppercase small">Blocked IPs</h6>
              <p class="display-6 mb-0"><%= metrics.blockedIpCount %></p>
            </div>
          </div>
        </div>
      </div>

      <div class="alert alert-light mb-4" role="alert">
        <strong>Traffic Source:</strong>
        <span class="badge bg-primary me-2">REAL_PCAP: <%= (sourceCounts && sourceCounts.realPcap) || 0 %></span>
        <span class="badge bg-secondary">SYNTHETIC: <%= (sourceCounts && sourceCounts.synthetic) || 0 %></span>
      </div>

      <div class="row g-4 mb-4">
        <div class="col-lg-8">
          <div class="card bg-secondary text-light h-100">
            <div class="card-body">
              <h5 class="card-title mb-3">Traffic &amp; Attack Trends</h5>
              <canvas id="trafficChart" height="140"></canvas>
            </div>
          </div>
        </div>
        <div class="col-lg-4">
          <div class="card bg-secondary text-light h-100">
            <div class="card-body">
              <h5 class="card-title mb-3">Recent Attacks</h5>
              <div class="table-responsive" style="max-height: 260px;">
                <table class="table table-sm table-dark table-striped align-middle">
                  <thead>
                    <tr>
                      <th>Time</th>
                      <th>Source IP</th>
                      <th>Dest IP</th>
                      <th>Severity</th>
                    </tr>
                  </thead>
                  <tbody>
                    <% if (recentAttacks && recentAttacks.length) { %>
                      <% recentAttacks.forEach(function (a) { %>
                        <tr>
                          <td><%= new Date(a.detected_at).toLocaleString() %></td>
                          <td><%= a.src_ip %></td>
                          <td><%= a.dest_ip %></td>
                          <td class="text-capitalize"><%= a.severity %></td>
                        </tr>
                      <% }) %>
                    <% } else { %>
                      <tr>
                        <td colspan="4" class="text-center text-muted">No attack logs yet.</td>
                      </tr>
                    <% } %>
                  </tbody>
                </table>
              </div>
            </div>
          </div>
        </div>
      </div>

      <div class="card bg-secondary text-light mb-4">
        <div class="card-body">
          <h5 class="card-title mb-3">Blocked IPs (Top 10)</h5>
          <div class="table-responsive">
            <table class="table table-sm table-dark table-striped align-middle">
              <thead>
                <tr>
                  <th>IP Address</th>
                  <th>Severity</th>
                  <th>First Blocked</th>
                  <th>Last Seen</th>
                </tr>
              </thead>
              <tbody>
                <% if (blockedIps && blockedIps.length) { %>
                  <% blockedIps.slice(0, 10).forEach(function (ip) { %>
                    <tr>
                      <td><%= ip.ip_address %></td>
                      <td class="text-capitalize"><%= ip.severity %></td>
                      <td><%= ip.first_blocked_at && new Date(ip.first_blocked_at).toLocaleString() %></td>
                      <td><%= ip.last_seen_at && new Date(ip.last_seen_at).toLocaleString() %></td>
                    </tr>
                  <% }) %>
                <% } else { %>
                  <tr>
                    <td colspan="4" class="text-center text-muted">No blocked IPs yet.</td>
                  </tr>
                <% } %>
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </main>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js"></script>
    <script id="traffic-data" type="application/json"><%- JSON.stringify(recentTraffic || []) %></script>
    <script>
      (function () {
        var dataEl = document.getElementById('traffic-data');
        var recentTraffic = dataEl ? JSON.parse(dataEl.textContent) : [];

        const buckets = {};
        recentTraffic.forEach(function (t) {
          if (!t.analyzed_at) return;
          const d = new Date(t.analyzed_at);
          const key = d.getHours().toString().padStart(2, '0') + ':00';
          if (!buckets[key]) {
            buckets[key] = { total: 0, attacks: 0 };
          }
          buckets[key].total += 1;
          if (t.is_attack) {
            buckets[key].attacks += 1;
          }
        });

        const labels = Object.keys(buckets).sort();
        const totalData = labels.map(function (l) { return buckets[l].total; });
        const attackData = labels.map(function (l) { return buckets[l].attacks; });

        const ctx = document.getElementById('trafficChart');
        if (ctx) {
          new Chart(ctx, {
            type: 'line',
            data: {
              labels: labels,
              datasets: [
                {
                  label: 'Total Flows',
                  data: totalData,
                  borderColor: 'rgba(75, 192, 192, 1)',
                  backgroundColor: 'rgba(75, 192, 192, 0.2)',
                  tension: 0.3
                },
                {
                  label: 'Attacks',
                  data: attackData,
                  borderColor: 'rgba(255, 99, 132, 1)',
                  backgroundColor: 'rgba(255, 99, 132, 0.2)',
                  tension: 0.3
                }
              ]
            },
            options: {
              responsive: true,
              plugins: {
                legend: {
                  labels: {
                    color: '#ffffff'
                  }
                }
              },
              scales: {
                x: {
                  ticks: { color: '#ffffff' },
                  grid: { color: 'rgba(255,255,255,0.1)' }
                },
                y: {
                  ticks: { color: '#ffffff' },
                  grid: { color: 'rgba(255,255,255,0.1)' },
                  beginAtZero: true
                }
              }
            }
          });
        }
      })();
    </script>
  </body>
  </html>

