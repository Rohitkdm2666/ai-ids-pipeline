<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" rel="stylesheet">
  <style>
    body { background: linear-gradient(135deg, #1e3a5f 0%, #0d1b2a 100%); min-height: 100vh; }
    .hero { padding: 100px 0; }
    .card { background: rgba(255,255,255,0.95); border: none; border-radius: 15px; }
    .btn-primary { background: #0d6efd; border: none; }
    .btn-primary:hover { background: #0b5ed7; }
    .feature-icon { font-size: 2.5rem; color: #0d6efd; }
    .navbar { background: rgba(0,0,0,0.3) !important; }
    .text-muted-light { color: rgba(255,255,255,0.7); }
  </style>
</head>
<body>
  <!-- Navigation -->
  <nav class="navbar navbar-expand-lg navbar-dark">
    <div class="container">
      <a class="navbar-brand" href="/">
        <i class="bi bi-shield-lock me-2"></i>SecureBank
      </a>
      <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
        <span class="navbar-toggler-icon"></span>
      </button>
      <div class="collapse navbar-collapse" id="navbarNav">
        <ul class="navbar-nav ms-auto">
          <li class="nav-item"><a class="nav-link" href="/">Home</a></li>
          <li class="nav-item"><a class="nav-link" href="/search">Search</a></li>
          <li class="nav-item"><a class="nav-link" href="/contact">Contact</a></li>
          <li class="nav-item"><a class="nav-link" href="/profile">Profile</a></li>
          <li class="nav-item"><a class="nav-link btn btn-outline-light btn-sm ms-2" href="/login">Login</a></li>
        </ul>
      </div>
    </div>
  </nav>

  <!-- Hero Section -->
  <section class="hero text-white">
    <div class="container text-center">
      <h1 class="display-4 fw-bold mb-4">Welcome to SecureBank</h1>
      <p class="lead text-muted-light mb-5">Your trusted partner in digital banking. Secure, fast, and reliable.</p>
      <div class="d-flex justify-content-center gap-3">
        <a href="/login" class="btn btn-primary btn-lg px-5">
          <i class="bi bi-box-arrow-in-right me-2"></i>Login
        </a>
        <a href="/contact" class="btn btn-outline-light btn-lg px-5">Contact Us</a>
      </div>
    </div>
  </section>

  <!-- Features -->
  <section class="py-5">
    <div class="container">
      <div class="row g-4">
        <div class="col-md-4">
          <div class="card h-100 p-4 text-center">
            <i class="bi bi-shield-check feature-icon mb-3"></i>
            <h5>Secure Transactions</h5>
            <p class="text-muted">Bank-grade encryption protects all your transactions.</p>
          </div>
        </div>
        <div class="col-md-4">
          <div class="card h-100 p-4 text-center">
            <i class="bi bi-lightning-charge feature-icon mb-3"></i>
            <h5>Fast Transfers</h5>
            <p class="text-muted">Send money instantly to anyone, anywhere.</p>
          </div>
        </div>
        <div class="col-md-4">
          <div class="card h-100 p-4 text-center">
            <i class="bi bi-headset feature-icon mb-3"></i>
            <h5>24/7 Support</h5>
            <p class="text-muted">Our team is always here to help you.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Quick Actions -->
  <section class="py-5 bg-light">
    <div class="container">
      <h3 class="text-center mb-4">Quick Actions</h3>
      <div class="row g-4">
        <div class="col-md-3">
          <a href="/search" class="card text-decoration-none h-100 p-3 text-center">
            <i class="bi bi-search text-primary fs-3"></i>
            <p class="mt-2 mb-0">Search</p>
          </a>
        </div>
        <div class="col-md-3">
          <a href="/profile" class="card text-decoration-none h-100 p-3 text-center">
            <i class="bi bi-person text-primary fs-3"></i>
            <p class="mt-2 mb-0">My Profile</p>
          </a>
        </div>
        <div class="col-md-3">
          <a href="/contact" class="card text-decoration-none h-100 p-3 text-center">
            <i class="bi bi-envelope text-primary fs-3"></i>
            <p class="mt-2 mb-0">Contact</p>
          </a>
        </div>
        <div class="col-md-3">
          <a href="/login" class="card text-decoration-none h-100 p-3 text-center">
            <i class="bi bi-box-arrow-in-right text-primary fs-3"></i>
            <p class="mt-2 mb-0">Login</p>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Footer -->
  <footer class="py-4 bg-dark text-white text-center">
    <div class="container">
      <p class="mb-0">&copy; 2024 SecureBank. This is a simulated victim application for IDS testing.</p>
    </div>
  </footer>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
